# Patron Database
PATRON_DB_HOST=localhost
PATRON_DB_PORT=5432
PATRON_DB_NAME=patron_db
PATRON_DB_USER=patron_user
PATRON_DB_PASSWORD=patron_pass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Analytics Database
ANALYTICS_DB_HOST=localhost
ANALYTICS_DB_PORT=5433
ANALYTICS_DB_NAME=analytics_db
ANALYTICS_DB_USER=analytics_user
ANALYTICS_DB_PASSWORD=analytics_pass

# Analytics Redis (AOF-persisted, used for event streaming)
ANALYTICS_REDIS_HOST=localhost
ANALYTICS_REDIS_PORT=6380

# App
PORT=3000
